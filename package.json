{
  "name": "simple-py",
  "private": true,
  "type": "module",
  "scripts": {
    "build-book": "myst build --html",
    "build-slides": "mkdir -p _build/html/slides && marp --input-dir slides --html -o _build/html/slides/",
    "build": "bun run build-book && bun run build-slides",
    "serve": "myst start",
    "clean": "rm -rf _build"
  },
  "dependencies": {
    "mystmd": "^1.0",
    "@marp-team/marp-cli": "^4.0"
  }
}
